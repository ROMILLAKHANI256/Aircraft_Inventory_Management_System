<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<?import javafx.scene.control.ToggleGroup?>
<AnchorPane prefHeight="450" prefWidth="402.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.6" fx:controller="com.fx.Aircraft_Inventory_Management_System.controllers.AddPartController">
    <Label layoutX="139.0" layoutY="24.0" text="Add Part" textAlignment="CENTER">
      <font>
         <Font size="32.0" />
      </font></Label>


    <Label layoutX="50" layoutY="100" text="ID:" />
    <TextField fx:id="idField" editable="false" layoutX="150" layoutY="95" />

    <Label layoutX="50" layoutY="140" text="Name:" />
    <TextField fx:id="nameField" layoutX="150" layoutY="135" />

    <Label layoutX="50" layoutY="180" text="Inventory:" />
    <TextField fx:id="invField" layoutX="150" layoutY="175" />

    <Label layoutX="50" layoutY="220" text="Price:" />
    <TextField fx:id="priceField" layoutX="150" layoutY="215" />

    <Label layoutX="50" layoutY="260" text="Max:" />
    <TextField fx:id="maxField" layoutX="150" layoutY="255" />

    <Label layoutX="50" layoutY="300" text="Min:" />
    <TextField fx:id="minField" layoutX="150" layoutY="295" />

    <Label fx:id="machineCompanyLabel" layoutX="50" layoutY="340" text="Machine ID:" />
    <TextField fx:id="machineCompanyField" layoutX="150" layoutY="335" />

    <Button layoutX="122.0" layoutY="403.0" onAction="#handleSave" text="Save" />
    <Button layoutX="221.0" layoutY="403.0" onAction="#handleCancel" text="Cancel" />
    <fx:define>
        <ToggleGroup fx:id="partTypeGroup" />
    </fx:define>
    <RadioButton fx:id="inHouseRadio" layoutX="107.0" layoutY="373.0"
                 text="In House" toggleGroup="$partTypeGroup" onAction="#handleInHouse" />

    <RadioButton fx:id="outsourcedRadio" layoutX="203.0" layoutY="373.0"
                 text="Outsourced" toggleGroup="$partTypeGroup" onAction="#handleOutsourced" />
</AnchorPane>
