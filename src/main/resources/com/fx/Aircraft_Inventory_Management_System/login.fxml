<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="300" prefWidth="400" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.6" fx:controller="com.fx.Aircraft_Inventory_Management_System.controllers.LoginController">
    <children>
        <Label layoutX="153.0" layoutY="14.0" text="Login">
         <font>
            <Font size="38.0" />
         </font></Label>
        <Label layoutX="80" layoutY="90" text="Username:" />
        <TextField fx:id="usernameField" layoutX="150" layoutY="85" />
        <Label layoutX="80" layoutY="140" text="Password:" />
        <PasswordField fx:id="passwordField" layoutX="150" layoutY="135" />
        <Button layoutX="127.0" layoutY="200.0" onAction="#onLoginClicked" text="Login" />
        <Button layoutX="200" layoutY="200" onAction="#onCancelClicked" text="Cancel" />
    </children>
</AnchorPane>
